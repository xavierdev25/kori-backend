generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Note {
  id            String     @id @default(uuid())
  type          NoteType
  status        NoteStatus @default(PENDING)

  recipientName String   @map("recipient_name")
  message       String?
  imageUrl      String?  @map("image_url")
  storagePath   String?  @map("storage_path")

  color         String?
  rotation      Int
  positionX     Int      @map("position_x")
  positionY     Int      @map("position_y")
  zIndex        Int      @map("z_index")

  ipHash        String?  @map("ip_hash")
  userAgentHash String?  @map("user_agent_hash")

  createdAt     DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@index([type, createdAt])
  @@index([status, createdAt])
  @@map("notes")
}

enum NoteType {
  TEXT
  DRAWING
}

/// Pre-moderación: las notas nacen PENDING y solo las APPROVED
/// aparecen en el muro público.
enum NoteStatus {
  PENDING
  APPROVED
}

/// Correos capturados por el "Coming soon" de la landing.
model Subscriber {
  id        String   @id @default(uuid())
  email     String   @unique
  ipHash    String?  @map("ip_hash")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@map("subscribers")
}

/// Ajustes editables desde el dashboard (contador, link del álbum…).
model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("app_settings")
}